{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "strict": false, // Temporarily disabled for Workers compatibility
    "noImplicitAny": false, // Temporarily relaxed for Workers compatibility
    "strictNullChecks": false, // Temporarily disabled for Workers compatibility
    "strictFunctionTypes": false, // Temporarily disabled for Workers compatibility
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": false, // Temporarily relaxed for Workers compatibility
    "exactOptionalPropertyTypes": false,
    "noUnusedLocals": false, // Temporarily relaxed for Workers compatibility
    "noUnusedParameters": false, // Temporarily relaxed for Workers compatibility
    "incremental": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": true,
    "noImplicitOverride": false, // Temporarily disabled for Workers compatibility
    "noPropertyAccessFromIndexSignature": false // Temporarily disabled for Workers compatibility
  },
  "include": [
    "src/**/*",
    "components/**/*",
    "pages/**/*",
    "services/**/*",
    "utils/**/*",
    "hooks/**/*",
    "constants/**/*",
    "types.ts",
    "App.tsx",
    "index.tsx",
    "vite.config.ts",
    "vite-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "services/advancedSupabasePool.ts",
    "services/apiResponseCache.ts",
    "services/edgeKVStorage.ts",
    "services/edgeOptimizationService.ts",
    "services/performanceBudget.ts",
    "services/performanceMonitorEnhanced.ts",
    "services/queryBatcher.ts",
    "services/realTimePerformanceMonitor.ts",
    "services/realUserMonitoring.ts",
    "services/realtimeConnectionManager.ts",
    "services/streamingQueryResults.ts",
    "services/supabaseOptimizationService.ts",
    "utils/seoConsolidated.tsx",
    "utils/seoEnhanced.tsx"
  ]
}