# Environment Variables Template
# Copy this file to .env.local for local development

# AI Configuration
VITE_API_KEY=your_google_gemini_api_key_here

# Supabase Configuration (Optional - will use LocalStorage if not provided)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Read Replica Configuration (Optional - for read scaling)
VITE_SUPABASE_READ_REPLICA_URL=your_supabase_read_replica_url
VITE_SUPABASE_READ_REPLICA_ANON_KEY=your_supabase_read_replica_anon_key

# Twelve Data API for real-time market data (Optional)
VITE_TWELVE_DATA_API_KEY=your_twelve_data_api_key

# Application Configuration
VITE_APP_NAME=QuantForge AI
VITE_APP_VERSION=1.0.0
VITE_APP_URL=https://quanforge.ai

# Production Optimizations
VITE_ENABLE_BUNDLE_ANALYZER=false
VITE_ENABLE_SERVICE_WORKER=true
VITE_ENABLE_PRELOAD=true
VITE_ENABLE_PREFETCH=true

# Performance Monitoring
VITE_ENABLE_WEB_VITALS=true
VITE_ENABLE_PERFORMANCE_MONITORING=true

# Edge Configuration
VITE_EDGE_RUNTIME=false
VITE_ENABLE_COMPRESSION=true
VITE_ENABLE_EDGE_FUNCTIONS=true

# Edge Optimization Configuration
EDGE_METRICS_ENDPOINT=/api/edge/metrics
EDGE_CACHE_WARMUP_INTERVAL=300000
EDGE_SECURITY_THRESHOLD=0.1
EDGE_CONNECTION_WARMING=true
EDGE_REGION_AFFINITY=true
EDGE_CACHE_TTL=3600
EDGE_MAX_CONNECTIONS=3
EDGE_MIN_CONNECTIONS=1
EDGE_HEALTH_CHECK_INTERVAL=15000
EDGE_WARMUP_CONCURRENT=3
EDGE_METRICS_SAMPLE_RATE=0.05

# Vercel Specific
VERCEL_ENV=production
VERCEL_URL=quanforge.ai
VERCEL_REGION=global

# Supabase Optimization
SUPABASE_POOL_SIZE=4
SUPABASE_CONNECTION_TIMEOUT=800
SUPABASE_QUERY_TIMEOUT=3000
SUPABASE_CACHE_TTL=180000

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true
VITE_ANALYTICS_ID=your_analytics_id

# Development/Production
NODE_ENV=development

# ==================== Dynamic Configuration System ====================
# The following environment variables replace hardcoded values throughout the codebase
# All variables are OPTIONAL - sensible defaults are provided

# Cache Configuration
VITE_CACHE_SEMANTIC_MAX_SIZE=1000
VITE_CACHE_SEMANTIC_MEMORY_MB=100
VITE_CACHE_SEMANTIC_TTL=300000
VITE_CACHE_SEMANTIC_CLEANUP_INTERVAL=60000
VITE_CACHE_UNIFIED_MAX_SIZE=10485760
VITE_CACHE_UNIFIED_TTL=300000
VITE_CACHE_UNIFIED_COMPRESSION_THRESHOLD=1024

# Database Configuration
VITE_DB_RETRY_MAX=5
VITE_DB_RETRY_DELAY=500
VITE_DB_QUERY_TIMEOUT=5000
VITE_DB_BATCH_SIZE=50
VITE_DB_CACHE_TTL=900000
VITE_DB_CACHE_MAX_SIZE=200

# Performance Configuration
VITE_PERF_MEMORY_LIMIT=4096
VITE_PERF_REQUEST_TIMEOUT=10000
VITE_PERF_BUNDLE_CHUNK_WARNING=100
VITE_PERF_CONCURRENCY=5

# Security Configuration
VITE_SEC_RATE_LIMIT_MAX=100
VITE_SEC_RATE_LIMIT_WINDOW=900000
VITE_SEC_MAX_FILE_SIZE=10
VITE_SEC_MAX_INPUT_LENGTH=10000

# Edge Runtime Configuration
VITE_EDGE_CACHING=true
VITE_EDGE_STATIC_CACHE_TTL=31536000
VITE_EDGE_API_CACHE_TTL=300000
VITE_EDGE_SLOW_QUERY_THRESHOLD=500
VITE_EDGE_REGIONS=hkg1,iad1,sin1,fra1,sfo1

# System Configuration
VITE_DEBUG=true