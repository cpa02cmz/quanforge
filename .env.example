# Environment Variables Template
# Copy this file to .env.local for local development

# AI Configuration
VITE_API_KEY=your_google_gemini_api_key_here

# Supabase Configuration (Optional - will use LocalStorage if not provided)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Read Replica Configuration (Optional - for read scaling)
VITE_SUPABASE_READ_REPLICA_URL=your_supabase_read_replica_url
VITE_SUPABASE_READ_REPLICA_ANON_KEY=your_supabase_read_replica_anon_key

# Twelve Data API for real-time market data (Optional)
VITE_TWELVE_DATA_API_KEY=your_twelve_data_api_key

# Application Configuration
VITE_APP_NAME=QuantForge AI
VITE_APP_VERSION=1.0.0
VITE_APP_URL=https://quanforge.ai

# Production Optimizations
VITE_ENABLE_BUNDLE_ANALYZER=false
VITE_ENABLE_SERVICE_WORKER=true
VITE_ENABLE_PRELOAD=true
VITE_ENABLE_PREFETCH=true

# Performance Monitoring
VITE_ENABLE_WEB_VITALS=true
VITE_ENABLE_PERFORMANCE_MONITORING=true

# Edge Configuration
VITE_EDGE_RUNTIME=false
VITE_ENABLE_COMPRESSION=true
VITE_ENABLE_EDGE_FUNCTIONS=true

# Edge Optimization Configuration
EDGE_METRICS_ENDPOINT=/api/edge/metrics
EDGE_CACHE_WARMUP_INTERVAL=300000
EDGE_SECURITY_THRESHOLD=0.1
EDGE_CONNECTION_WARMING=true
EDGE_REGION_AFFINITY=true
EDGE_CACHE_TTL=3600
EDGE_MAX_CONNECTIONS=3
EDGE_MIN_CONNECTIONS=1
EDGE_HEALTH_CHECK_INTERVAL=15000
EDGE_WARMUP_CONCURRENT=3
EDGE_METRICS_SAMPLE_RATE=0.05

# Vercel Specific
VERCEL_ENV=production
VERCEL_URL=quanforge.ai
VERCEL_REGION=global

# Supabase Optimization
SUPABASE_POOL_SIZE=4
SUPABASE_CONNECTION_TIMEOUT=800
SUPABASE_QUERY_TIMEOUT=3000
SUPABASE_CACHE_TTL=180000

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true
VITE_ANALYTICS_ID=your_analytics_id

# Development/Production
NODE_ENV=development

# Security Configuration
VITE_MAX_PAYLOAD_SIZE=5242880
VITE_ALLOWED_ORIGINS=https://quanforge.ai,https://www.quanforge.ai,http://localhost:3000,http://localhost:5173
VITE_RATE_LIMIT_WINDOW=60000
VITE_RATE_LIMIT_MAX=100
VITE_ENCRYPTION_ALGORITHM=AES-256-GCM
VITE_ENCRYPTION_KEY_ROTATION=43200000
VITE_EDGE_RATE_LIMIT_ENABLED=true
VITE_EDGE_RATE_LIMIT_RPS=10
VITE_EDGE_RATE_LIMIT_BURST=20
VITE_EDGE_RATE_LIMIT_WINDOW=1000
VITE_REGION_BLOCKING_ENABLED=true
VITE_BLOCKED_REGIONS=CN,RU,IR,KP
VITE_BOT_DETECTION_ENABLED=true
VITE_SUSPICIOUS_BOT_PATTERNS=bot,crawler,spider,scraper

# Validation Limits
VITE_NAME_MIN_LENGTH=3
VITE_NAME_MAX_LENGTH=100
VITE_DESCRIPTION_MAX_LENGTH=1000
VITE_RISK_MIN_PERCENTAGE=0.01
VITE_RISK_MAX_PERCENTAGE=100
VITE_DEPOSIT_MIN_AMOUNT=100
VITE_DEPOSIT_MAX_AMOUNT=10000000
VITE_BACKTEST_MIN_DAYS=1
VITE_BACKTEST_MAX_DAYS=365

# Company Information
VITE_COMPANY_NAME=QuantForge AI
VITE_SITE_URL=https://quanforge.ai
VITE_COMPANY_EMAIL=contact@quanforge.ai
VITE_COMPANY_PHONE=+1-555-0123
VITE_COMPANY_ADDRESS=123 Tech Street, San Francisco, CA 94105
VITE_COMPANY_TWITTER=https://twitter.com/quanforge
VITE_COMPANY_LINKEDIN=https://linkedin.com/company/quanforge
VITE_COMPANY_GITHUB=https://github.com/quanforge

# Performance Configuration
VITE_MAX_RETRIES=5
VITE_RETRY_DELAY=500
VITE_BACKOFF_MULTIPLIER=1.5
VITE_MAX_DELAY=10000
VITE_RETRY_JITTER=true
VITE_CACHE_TTL=900000
VITE_CACHE_MAX_SIZE=200
VITE_SLOW_QUERY_THRESHOLD=1000
VITE_SLOW_OPERATION_THRESHOLD=500
VITE_DB_QUERY_LIMIT=100
VITE_AI_CACHE_SIZE=100
VITE_AI_DEFAULT_TTL=300000
VITE_METRICS_FREQUENCY=30000
VITE_ALERT_THRESHOLD=0.8

# URLs and Endpoints
VITE_BASE_URL=https://quanforge.ai
VITE_API_BASE_URL=https://api.quanforge.ai
VITE_DEV_URL=http://localhost:3000
VITE_DEV_PORT=3000
VITE_TWITTER_URL=https://twitter.com/quanforge
VITE_LINKEDIN_URL=https://linkedin.com/company/quanforge
VITE_GITHUB_URL=https://github.com/quanforge

# Analytics
VITE_GA_ID=G-XXXXXXXXXX
VITE_SITE_VERIFICATION_KEY=your-google-verification-code