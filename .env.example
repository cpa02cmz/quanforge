# Environment Variables Template
# Copy this file to .env.local for local development

# AI Configuration
VITE_API_KEY=your_google_gemini_api_key_here

# Supabase Configuration (Optional - will use LocalStorage if not provided)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Read Replica Configuration (Optional - for read scaling)
VITE_SUPABASE_READ_REPLICA_URL=your_supabase_read_replica_url
VITE_SUPABASE_READ_REPLICA_ANON_KEY=your_supabase_read_replica_anon_key

# Twelve Data API for real-time market data (Optional)
VITE_TWELVE_DATA_API_KEY=your_twelve_data_api_key

# Application Configuration
VITE_APP_NAME=QuantForge AI
VITE_APP_VERSION=1.0.0
VITE_APP_URL=https://quanforge.ai

# Production Optimizations
VITE_ENABLE_BUNDLE_ANALYZER=false
VITE_ENABLE_SERVICE_WORKER=true
VITE_ENABLE_PRELOAD=true
VITE_ENABLE_PREFETCH=true

# Performance Monitoring
VITE_ENABLE_WEB_VITALS=true
VITE_ENABLE_PERFORMANCE_MONITORING=true

# Edge Configuration
VITE_EDGE_RUNTIME=false
VITE_ENABLE_COMPRESSION=true
VITE_ENABLE_EDGE_FUNCTIONS=true

# Edge Optimization Configuration
EDGE_METRICS_ENDPOINT=/api/edge/metrics
EDGE_CACHE_WARMUP_INTERVAL=300000
EDGE_SECURITY_THRESHOLD=0.1
EDGE_CONNECTION_WARMING=true
EDGE_REGION_AFFINITY=true
EDGE_CACHE_TTL=3600
EDGE_MAX_CONNECTIONS=3
EDGE_MIN_CONNECTIONS=1
EDGE_HEALTH_CHECK_INTERVAL=15000
EDGE_WARMUP_CONCURRENT=3
EDGE_METRICS_SAMPLE_RATE=0.05

# Vercel Specific
VERCEL_ENV=production
VERCEL_URL=quanforge.ai
VERCEL_REGION=global

# Supabase Optimization
SUPABASE_POOL_SIZE=4
SUPABASE_CONNECTION_TIMEOUT=800
SUPABASE_QUERY_TIMEOUT=3000
SUPABASE_CACHE_TTL=180000

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true
VITE_ANALYTICS_ID=your_analytics_id

# Development/Production
NODE_ENV=development

# ===== CENTRALIZED CONFIGURATION =====
# These environment variables replace hardcoded values throughout the application

# Retry Configuration
VITE_MAX_RETRIES=5
VITE_RETRY_DELAY=500
VITE_BACKOFF_MULTIPLIER=1.5
VITE_MAX_DELAY=10000
VITE_RETRY_JITTER=true

# Cache Configuration
VITE_CACHE_TTL=900000  # 15 minutes in milliseconds
VITE_CACHE_MAX_SIZE=200

# Security Configuration  
VITE_MAX_PAYLOAD_SIZE=5242880  # 5MB in bytes
VITE_ALLOWED_ORIGINS=["https://quanforge.ai","https://www.quanforge.ai","http://localhost:3000","http://localhost:5173"]
VITE_RATE_LIMIT_WINDOW=60000  # 1 minute in milliseconds
VITE_RATE_LIMIT_MAX=100
VITE_ENCRYPTION_ALGORITHM=AES-256-GCM
VITE_KEY_ROTATION_INTERVAL=43200000  # 12 hours in milliseconds

# Edge Security Configuration
VITE_EDGE_RATE_LIMITING=true
VITE_EDGE_RPS=10
VITE_EDGE_BURST_LIMIT=20
VITE_REGION_BLOCKING=true
VITE_BLOCKED_REGIONS=["CN","RU","IR","KP"]
VITE_BOT_DETECTION=true
VITE_SUSPICIOUS_PATTERNS=["sqlmap","nikto","nmap","masscan","dirb","gobuster","wfuzz","burp","owasp","scanner","bot","crawler","spider"]

# Performance Configuration
VITE_BATCH_SIZE=10
VITE_PERF_CACHE_TTL=300000  # 5 minutes in milliseconds
VITE_CONNECTION_TIMEOUT=10000  # 10 seconds in milliseconds
VITE_REQUEST_TIMEOUT=30000  # 30 seconds in milliseconds

# Specialized Cache Configurations
VITE_ROBOTS_CACHE_TTL=600000  # 10 minutes in milliseconds
VITE_ROBOTS_CACHE_MAX_SIZE=52428800  # 50MB in bytes
VITE_MARKET_DATA_CACHE_TTL=30000  # 30 seconds in milliseconds
VITE_MARKET_DATA_CACHE_MAX_SIZE=20971520  # 20MB in bytes
VITE_ANALYSIS_CACHE_TTL=900000  # 15 minutes in milliseconds
VITE_ANALYSIS_CACHE_MAX_SIZE=31457280  # 30MB in bytes
VITE_AI_RESPONSES_CACHE_TTL=900000  # 15 minutes in milliseconds
VITE_AI_RESPONSES_CACHE_MAX_SIZE=200
VITE_STATIC_CACHE_TTL=3600000  # 1 hour in milliseconds
VITE_STATIC_CACHE_MAX_SIZE=20971520  # 20MB in bytes